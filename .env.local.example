# ============================================================================
# Perfect Walk - Environment Configuration Template
# Copy this file to .env.local and fill in your actual API keys and secrets
# ============================================================================

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# NextAuth Secret Key (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-key-here

# ============================================================================
# GOOGLE OAUTH & APIS
# ============================================================================

# Google OAuth Configuration (https://console.cloud.google.com/)
# Create OAuth 2.0 credentials and enable Google Calendar API
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Places API Key (https://console.cloud.google.com/)
# Enable "Places API" in your Google Cloud project
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ============================================================================
# WEATHER API
# ============================================================================

# OpenWeather API Key (https://openweathermap.org/api)
# Sign up for free account to get API key
OPENWEATHER_API_KEY=your-openweather-api-key

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# FastAPI Backend URL
# Local development: http://localhost:8000
# Production: Update with your backend domain
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ============================================================================
# AZURE OPENAI (Optional - for AI features)
# ============================================================================

# Azure OpenAI Configuration (https://azure.microsoft.com/en-us/products/ai-services/openai-service)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-model/chat/completions?api-version=2024-02-01
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_MODEL=gpt-4.1-mini

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in your actual API keys and secrets
# 3. Never commit .env.local to version control
# 4. See README.md for detailed setup instructions

# ============================================================================
# REQUIRED vs OPTIONAL VARIABLES
# ============================================================================

# REQUIRED for basic functionality:
# - AUTH_SECRET
# - GOOGLE_CLIENT_ID  
# - GOOGLE_CLIENT_SECRET

# OPTIONAL for enhanced features:
# - GOOGLE_PLACES_API_KEY (for location features)
# - OPENWEATHER_API_KEY (for weather integration)  
# - NEXT_PUBLIC_BACKEND_URL (for backend integration)
# - AZURE_OPENAI_* (for AI recommendations)

